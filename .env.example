ENVIRONMENT=local

# Server
SERVER_PORT=4000

# SQLite database file path
DB_PATH=./solo-grabber.db

# Directory for job output and reference photos
JOBS_DIR=./jobs

# Python pipeline
PYTHON_BIN=python
PYTHON_SCRIPT_PATH=./scripts/process_video.py

# Audio fingerprint built from reference recording (build_fingerprint.py)
FINGERPRINT_PATH=./scripts/me_fingerprint.json

# Nightly Smalls cron (set to true in production)
SMALLS_CRON_ENABLED=false
SMALLS_CRON_SCHEDULE="CRON_TZ=America/New_York 0 0 5 * * *"

# API key (required in non-local environments)
API_KEY=your-secret-key-here

# Cloudflare R2 (leave blank to skip uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=solo-grabber
R2_PUBLIC_BASE_URL=https://clips.yourdomain.com
